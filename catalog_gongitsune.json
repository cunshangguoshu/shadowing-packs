        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_07.mp3",
          "japaneseText": "つぎの日、ごんは、栗をひろって、兵十の家へ持っていってやりました。",
