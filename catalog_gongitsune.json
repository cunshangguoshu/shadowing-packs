        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_09.mp3",
          "japaneseText": "「おれにはお礼を言わないで、神様にお礼を言うなんて、引き合わないなあ。」",
          "translation": "“对我一句感谢都不说，却对神明去道谢，真是太亏了啊。”",
          "rubySegments": [
            {
              "text": "「おれには",
              "ruby": "「おれには",
              "translation": "「对我"
