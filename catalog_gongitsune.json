          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_11.mp3",
          "japaneseText": "兵十は、火縄銃をとって、ドンと、ごんを撃ちました。",
          "translation": "兵十拿起了火绳枪，砰地一声，击中了阿权。",
          "rubySegments": [
