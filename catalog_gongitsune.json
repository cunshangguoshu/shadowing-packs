        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_10.mp3",
          "japaneseText": "そのあくる日も、ごんは、栗を持って、兵十の家へ入っていきました。",
          "translation": "又过了一天，阿权带着栗子，走进了兵十的家。",
          "rubySegments": [
